# Gemini
gemini_api_key=

# LLM model for every generation task (PLAN 8.1)
gemini_model=gemini-3.5-flash

# File Search store name, injected after Phase 1 upload script runs (PLAN 8.3)
file_search_store_name=

# GCP project for Firestore, wired in Phase 4 (PLAN 9.1)
gcp_project_id=

# Interview pacing and axis coverage, tunable during the pilot (PLAN 3.2)
interview_target_turns=15
interview_wrapup_turn=12
axis_min_evidence=2
